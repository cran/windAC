Type: Package
Package: windAC
Title: Area Correction Methods
Version: 1.3.0
Date: 2026-04-29
Authors@R: c(
    person("Paul", "Rabie", role = "aut"),
    person("Daniel", "Riser-Espinoza", , "despinoza@west-inc.com", role = c("aut", "cre")),
